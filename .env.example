# =============================================================================
# B2B Visitor SaaS - Environment Variables
# =============================================================================
# Kopieer naar .env (root) EN naar apps/web/.env
# Next.js laadt env vars uit apps/web/ - beide bestanden nodig in monorepo.
# =============================================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://pmdrdibvirpktcdogvwg.supabase.co
# Anon key OF Publishable key (beide werken)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database URL voor Drizzle (zelfde als Supabase Postgres)
# Vervang [YOUR-PASSWORD] met je database wachtwoord uit Supabase Dashboard
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.pmdrdibvirpktcdogvwg.supabase.co:5432/postgres

# --- Trigger.dev ---
# Haal je DEV secret key op van: https://cloud.trigger.dev → Project → API Keys
TRIGGER_SECRET_KEY=tr_dev_xxx
TRIGGER_API_URL=https://api.trigger.dev

# --- Vercel (bij deploy) ---
# Wordt automatisch gezet door Vercel

# --- Optional: Sentry ---
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
