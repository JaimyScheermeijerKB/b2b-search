{
  "name": "b2b-visitor-saas",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter web dev",
    "dev:restart": "pkill -f 'next dev' 2>/dev/null; rm -f apps/web/.next/dev/lock 2>/dev/null; pnpm dev",
    "build": "pnpm --filter './packages/*' build && pnpm --filter web build",
    "lint": "eslint \"packages/**/*.ts\" \"apps/**/*.ts\" \"apps/**/*.tsx\" --no-error-on-unmatched-pattern",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:generate": "pnpm --filter db generate",
    "db:migrate": "pnpm --filter db migrate",
    "db:push": "pnpm --filter db push",
    "db:studio": "pnpm --filter db studio",
    "worker:dev": "pnpm --filter worker dev",
    "worker:deploy": "pnpm --filter worker deploy"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^20.10.0",
    "eslint": "^9.0.0",
    "prettier": "^3.2.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20"
  }
}
